# Environment variables (contains API keys)
.env

# Data directory (db, models, cache); .gitkeep is tracked
.data/*
!.data/.gitkeep

# Legacy / root-level DB files
*.db
*.db-journal
*.db-wal
*.db-shm
*.db.backup

# ML models / cache (also under .data)
*.joblib
*.pkl
*.pickle

# Raw data
data/

# Stock images (too large for git)
server/static/images/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg
.venv/
venv/
env/

# Node / App (UI)
app/node_modules/
app/dist/
app/.vite/

# Logs
logs/
*.log

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# OS
Thumbs.db
