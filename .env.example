# 可选：在仓库根目录创建 .env.path，文件内仅一行：要使用的 .env 的绝对路径或相对本仓库根的路径；
# 用于强制指定密钥文件，无需在终端 export（见 server/config.py resolved_env_file_path）。

# Polygon.io API key (free tier available)
# Sign up at: https://polygon.io/
POLYGON_API_KEY=your_polygon_api_key_here

# Claude：默认走 API易 网关（与官方 Anthropic SDK 兼容）
# 密钥在 https://apiyi.com 控制台创建；勿带 /v1
ANTHROPIC_BASE_URL=https://api.apiyi.com
ANTHROPIC_API_KEY=your_apiyi_sk_here
# API易 控制台里的 Claude 模型 id（与官方日期后缀可能不同）
ANTHROPIC_MODEL_SONNET=claude-sonnet-4-6

# 若改回 Anthropic 官方：ANTHROPIC_BASE_URL=https://api.anthropic.com 与 console 的 key，并把模型名改成官方页面上的 id
